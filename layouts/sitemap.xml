{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\"?>" | safeHTML }}
{{- $base := .Site.BaseURL -}}
{{- $now := now.Format "2006-01-02T15:04:05-07:00" -}}
<sitemapindex xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <sitemap>
    <loc>{{ printf "%ssitemap_posts.xml" $base }}</loc>
    <lastmod>{{ $now }}</lastmod>
  </sitemap>
  <sitemap>
    <loc>{{ printf "%ssitemap_hubs.xml" $base }}</loc>
    <lastmod>{{ $now }}</lastmod>
  </sitemap>
  <sitemap>
    <loc>{{ printf "%ssitemap_categories.xml" $base }}</loc>
    <lastmod>{{ $now }}</lastmod>
  </sitemap>
  <sitemap>
    <loc>{{ printf "%ssitemap_pages.xml" $base }}</loc>
    <lastmod>{{ $now }}</lastmod>
  </sitemap>
</sitemapindex>
